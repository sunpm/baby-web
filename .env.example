# Supabase 项目 API 地址 (在 Supabase 控制台 Settings -> API 中查看)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 匿名 Key (Anon Key)，用于前端安全访问数据
VITE_SUPABASE_ANON_KEY=your-anon-key

# 应用中显示的宝宝昵称或家庭名称
VITE_BABY_HOUSEHOLD_NAME=我家宝宝

# 数据库连接字符串 (Postgres Direct Connection)
# 注意：此变量仅在服务端使用，请勿在 Vite 前端代码中引用，以防泄露数据库密码
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
